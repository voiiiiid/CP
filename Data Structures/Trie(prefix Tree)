class TrieNode:
    def __init__(self):
        self.child = {}
        self.end = False


class Trie:

    def __init__(self):
        self.root = TrieNode()

    def insert(self, word: str) -> None:
        curr = self.root

        for ch in word:

            if ch not in curr.child:
                curr.child[ch] = TrieNode()
            
            curr = curr.child[ch]
        
        curr.end = True

    def search(self, word: str) -> bool:
        node = self.root

        for ch in word:
            if ch not in node.child:
                return False
            
            node = node.child[ch]
        
        if node.end:
            return True
        return False

    def startsWith(self, prefix: str) -> bool:
        node = self.root

        for ch in prefix:
            if ch not in node.child:
                return False
            
            node = node.child[ch]
        
        return True
